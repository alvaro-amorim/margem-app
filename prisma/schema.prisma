generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum PlatformRole {
  USER
  ADMIN
}

enum PlatformUserStatus {
  ACTIVE
  BLOCKED
}

enum WorkspacePlan {
  FREE
  PREMIUM
}

enum BaseUnit {
  GRAM
  MILLILITER
  UNIT
}

enum PurchaseUnit {
  GRAM
  KILOGRAM
  MILLILITER
  LITER
  UNIT
  DOZEN
  PACK
  BOX
  BOTTLE
  CAN
  BAG
  JAR
  POT
  TRAY
  SACK
}

model User {
  id                 String                   @id @default(cuid())
  clerkUserId        String                   @unique
  email              String?
  firstName          String?
  lastName           String?
  imageUrl           String?
  platformRole       PlatformRole             @default(USER)
  status             PlatformUserStatus       @default(ACTIVE)
  blockedReason      String?
  blockedAt          DateTime?
  defaultWorkspaceId String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  defaultWorkspace   Workspace?               @relation("UserDefaultWorkspace", fields: [defaultWorkspaceId], references: [id], onDelete: SetNull)
  ingredients        Ingredient[]             @relation("IngredientAuthor")
  memberships        WorkspaceMember[]
  ownedWorkspaces    Workspace[]              @relation("WorkspaceOwner")
  priceHistory       IngredientPriceHistory[] @relation("PriceHistoryActor")
  pricingRuns        PricingRun[]             @relation("PricingRunActor")
  recipes            Recipe[]                 @relation("RecipeAuthor")
}

model Workspace {
  id              String                   @id @default(cuid())
  name            String
  slug            String                   @unique
  ownerId         String
  plan            WorkspacePlan            @default(FREE)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  ingredients     Ingredient[]
  memberships     WorkspaceMember[]
  owner           User                     @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  priceHistory    IngredientPriceHistory[]
  pricingRuns     PricingRun[]
  pricingSettings PricingSettings?
  recipeProfiles  RecipePricingProfile[]
  recipes         Recipe[]
  usersDefaulting User[]                   @relation("UserDefaultWorkspace")
}

model WorkspaceMember {
  id          String              @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceMemberRole @default(OWNER)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Ingredient {
  id                   String                   @id @default(cuid())
  workspaceId          String
  createdById          String?
  name                 String
  category             String?
  brand                String?
  purchaseLocation     String?
  purchaseUnit         PurchaseUnit
  baseUnit             BaseUnit
  purchaseQuantity     Decimal                  @db.Decimal(12, 3)
  purchasePrice        Decimal                  @db.Decimal(12, 2)
  conversionFactor     Decimal                  @db.Decimal(12, 4)
  unitCostInBaseUnit   Decimal                  @db.Decimal(14, 6)
  notes                String?
  isActive             Boolean                  @default(true)
  lastPriceConfirmedAt DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  createdBy            User?                    @relation("IngredientAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  priceHistory         IngredientPriceHistory[]
  recipeItems          RecipeItem[]
  workspace            Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId, category])
}

model IngredientPriceHistory {
  id                 String       @id @default(cuid())
  workspaceId        String
  ingredientId       String
  recordedById       String?
  brand              String?
  purchaseLocation   String?
  purchaseQuantity   Decimal      @db.Decimal(12, 3)
  purchaseUnit       PurchaseUnit
  baseUnit           BaseUnit
  conversionFactor   Decimal      @db.Decimal(12, 4)
  purchasePrice      Decimal      @db.Decimal(12, 2)
  unitCostInBaseUnit Decimal      @db.Decimal(14, 6)
  priceChanged       Boolean      @default(true)
  changeNote         String?
  effectiveDate      DateTime     @default(now())
  createdAt          DateTime     @default(now())
  ingredient         Ingredient   @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  recordedBy         User?        @relation("PriceHistoryActor", fields: [recordedById], references: [id], onDelete: SetNull)
  workspace          Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([ingredientId, effectiveDate])
  @@index([workspaceId, effectiveDate])
}

model Recipe {
  id               String                @id @default(cuid())
  workspaceId      String
  createdById      String?
  name             String
  description      String?
  yieldQuantity    Decimal               @db.Decimal(12, 3)
  yieldUnitLabel   String
  servingQuantity  Decimal               @db.Decimal(12, 3)
  servingUnitLabel String
  notes            String?
  isArchived       Boolean               @default(false)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  createdBy        User?                 @relation("RecipeAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  items            RecipeItem[]
  pricingProfile   RecipePricingProfile?
  pricingRuns      PricingRun[]
  workspace        Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId, isArchived])
}

model RecipeItem {
  id                 String     @id @default(cuid())
  recipeId           String
  ingredientId       String
  quantityInBaseUnit Decimal    @db.Decimal(12, 3)
  notes              String?
  sortOrder          Int        @default(0)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  ingredient         Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  recipe             Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
  @@index([recipeId, sortOrder])
}

model PricingSettings {
  id                   String    @id @default(cuid())
  workspaceId          String    @unique
  wastePercent         Decimal   @default(0) @db.Decimal(5, 2)
  packagingCost        Decimal   @default(0) @db.Decimal(12, 2)
  laborCost            Decimal   @default(0) @db.Decimal(12, 2)
  energyCost           Decimal   @default(0) @db.Decimal(12, 2)
  fixedOverheadCost    Decimal   @default(0) @db.Decimal(12, 2)
  commissionPercent    Decimal   @default(0) @db.Decimal(5, 2)
  taxPercent           Decimal   @default(0) @db.Decimal(5, 2)
  targetMarginPercent  Decimal   @default(0) @db.Decimal(5, 2)
  includePackaging     Boolean   @default(false)
  includeLabor         Boolean   @default(false)
  includeEnergy        Boolean   @default(false)
  includeFixedOverhead Boolean   @default(false)
  includeCommission    Boolean   @default(false)
  includeTax           Boolean   @default(false)
  includeTargetMargin  Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model RecipePricingProfile {
  id                   String    @id @default(cuid())
  workspaceId          String
  recipeId             String    @unique
  includeIngredients   Boolean   @default(true)
  includeWaste         Boolean   @default(true)
  wastePercent         Decimal   @default(0) @db.Decimal(5, 2)
  includePackaging     Boolean   @default(false)
  packagingCost        Decimal   @default(0) @db.Decimal(12, 2)
  includeLabor         Boolean   @default(false)
  laborCost            Decimal   @default(0) @db.Decimal(12, 2)
  includeEnergy        Boolean   @default(false)
  energyCost           Decimal   @default(0) @db.Decimal(12, 2)
  includeFixedOverhead Boolean   @default(false)
  fixedOverheadCost    Decimal   @default(0) @db.Decimal(12, 2)
  includeCommission    Boolean   @default(false)
  commissionPercent    Decimal   @default(0) @db.Decimal(5, 2)
  includeTax           Boolean   @default(false)
  taxPercent           Decimal   @default(0) @db.Decimal(5, 2)
  includeTargetMargin  Boolean   @default(true)
  targetMarginPercent  Decimal   @default(0) @db.Decimal(5, 2)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  recipe               Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model PricingRun {
  id                  String    @id @default(cuid())
  workspaceId         String
  recipeId            String
  createdById         String?
  snapshotVersion     Int       @default(1)
  recipeName          String
  yieldQuantity       Decimal   @db.Decimal(12, 3)
  yieldUnitLabel      String
  servingQuantity     Decimal   @db.Decimal(12, 3)
  servingUnitLabel    String
  ingredientCostTotal Decimal   @db.Decimal(12, 2)
  additionalCostTotal Decimal   @db.Decimal(12, 2)
  totalCost           Decimal   @db.Decimal(12, 2)
  costPerServing      Decimal   @db.Decimal(12, 2)
  breakEvenPrice      Decimal   @db.Decimal(12, 2)
  suggestedPrice      Decimal   @db.Decimal(12, 2)
  targetMarginPercent Decimal   @db.Decimal(5, 2)
  inputSnapshot       Json
  resultSnapshot      Json
  createdAt           DateTime  @default(now())
  createdBy           User?     @relation("PricingRunActor", fields: [createdById], references: [id], onDelete: SetNull)
  recipe              Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([recipeId, createdAt])
}

model EmailBlocklist {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
